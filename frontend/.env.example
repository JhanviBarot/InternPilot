# ── Backend URL ────────────────────────────────────────────────────────────────
# In production set this to your backend public URL (no trailing slash).
# Leave empty to proxy /api calls to the same origin (same-domain deployment).
VITE_API_BASE_URL=

# ── Mock data (dev only) ───────────────────────────────────────────────────────
# Set to "true" to use local mock data instead of the real API.
# Never set in production.
VITE_USE_MOCKS=false
